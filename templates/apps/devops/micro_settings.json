{
    "colorscheme": "simple",
    "mouse": true,
    "savecursor": true,
    "saveundo": true,
    "scrollbar": true,
    "tabsize": 4,
    "autoindent": true,
    "autosu": true,
    "cursorline": true,
    "eofnewline": true,
    "fastdirty": true,
    "mkparents": true,
    "rmtrailingws": true,
    "softwrap": true,
    "tabstospaces": true,
    "wordwrap": true,
    "basename": true,
    "ignorecase": true,
    "matchbrace": true,
    "matchbracewait": "50ms",
    "ruler": true,
    "incsearch": true,
    "smartpaste": true,
    "sucmd": "sudo"
}
